{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-bounce",
  "cssVars": {
    "theme": {
      "--animate-bounce": "bounce 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes bounce": {
        "0%, 20%, 50%, 80%, 100%": {
          "transform": "translateY(0)"
        },
        "40%": {
          "transform": "translateY(-30px)"
        },
        "60%": {
          "transform": "translateY(-15px)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}