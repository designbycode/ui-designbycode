{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme-retro-terminal",
  "title": "Theme Retro Terminal",
  "author": "designbycode",
  "registryDependencies": [
    "https://ui.designbycode.co.za/r/font-ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-sans": "'IBM Plex Mono', monospace",
      "--font-serif": "'IBM Plex Mono', monospace",
      "--font-mono": "'IBM Plex Mono', monospace",
      "--radius-sm": "0",
      "--radius-md": "0",
      "--radius-lg": "0",
      "--radius-xl": "0.25rem"
    },
    "light": {
      "--background": "oklch(0.98 0.01 140)",
      "--foreground": "oklch(0.25 0.08 140)",
      "--card": "oklch(0.98 0.01 140)",
      "--card-foreground": "oklch(0.25 0.08 140)",
      "--popover": "oklch(0.98 0.01 140)",
      "--popover-foreground": "oklch(0.25 0.08 140)",
      "--primary": "oklch(0.35 0.15 140)",
      "--primary-foreground": "oklch(0.98 0.01 140)",
      "--secondary": "oklch(0.92 0.02 140)",
      "--secondary-foreground": "oklch(0.4 0.06 140)",
      "--muted": "oklch(0.94 0.02 140)",
      "--muted-foreground": "oklch(0.5 0.05 140)",
      "--accent": "oklch(0.55 0.18 40)",
      "--accent-foreground": "oklch(0.98 0.01 140)",
      "--destructive": "oklch(0.7 0.22 25)",
      "--destructive-foreground": "oklch(0.98 0.01 140)",
      "--border": "oklch(0.85 0.03 140)",
      "--input": "oklch(0.85 0.03 140)",
      "--ring": "oklch(0.35 0.15 140)",
      "--chart-1": "oklch(0.35 0.15 140)",
      "--chart-2": "oklch(0.55 0.18 40)",
      "--chart-3": "oklch(0.7 0.18 200)",
      "--chart-4": "oklch(0.65 0.15 280)",
      "--chart-5": "oklch(0.6 0.15 160)",
      "--sidebar": "oklch(0.96 0.01 140)",
      "--sidebar-foreground": "oklch(0.25 0.08 140)",
      "--sidebar-primary": "oklch(0.35 0.15 140)",
      "--sidebar-primary-foreground": "oklch(0.98 0.01 140)",
      "--sidebar-accent": "oklch(0.55 0.18 40)",
      "--sidebar-accent-foreground": "oklch(0.98 0.01 140)",
      "--sidebar-border": "oklch(0.85 0.03 140)",
      "--sidebar-ring": "oklch(0.35 0.15 140)",
      "--shadow-sm": "0 1px 2px hsl(140 30% 60% / 0.05)",
      "--shadow": "0 2px 4px hsl(140 30% 60% / 0.1)",
      "--shadow-md": "0 4px 8px hsl(140 30% 60% / 0.15)",
      "--shadow-lg": "0 6px 16px hsl(140 30% 60% / 0.2)",
      "--shadow-xl": "0 10px 30px hsl(140 30% 60% / 0.25)"
