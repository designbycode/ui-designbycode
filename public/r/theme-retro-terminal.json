    "dark": {
      "--background": "oklch(0.05 0.02 140)",
      "--foreground": "oklch(0.75 0.2 140)",
      "--card": "oklch(0.08 0.02 140)",
      "--card-foreground": "oklch(0.75 0.2 140)",
      "--popover": "oklch(0.08 0.02 140)",
      "--popover-foreground": "oklch(0.75 0.2 140)",
      "--primary": "oklch(0.75 0.2 140)",
      "--primary-foreground": "oklch(0.08 0.02 140)",
      "--secondary": "oklch(0.25 0.04 140)",
      "--secondary-foreground": "oklch(0.7 0.15 140)",
      "--muted": "oklch(0.15 0.03 140)",
      "--muted-foreground": "oklch(0.55 0.1 140)",
      "--accent": "oklch(0.8 0.18 40)",
      "--accent-foreground": "oklch(0.08 0.02 140)",
      "--destructive": "oklch(0.7 0.22 25)",
      "--destructive-foreground": "oklch(0.08 0.02 140)",
      "--border": "oklch(0.25 0.04 140)",
      "--input": "oklch(0.25 0.04 140)",
      "--ring": "oklch(0.75 0.2 140)",
      "--chart-1": "oklch(0.75 0.2 140)",
      "--chart-2": "oklch(0.8 0.18 40)",
      "--chart-3": "oklch(0.7 0.18 200)",
      "--chart-4": "oklch(0.65 0.15 280)",
      "--chart-5": "oklch(0.6 0.15 160)",
      "--sidebar": "oklch(0.04 0.02 140)",
      "--sidebar-foreground": "oklch(0.75 0.2 140)",
      "--sidebar-primary": "oklch(0.75 0.2 140)",
      "--sidebar-primary-foreground": "oklch(0.08 0.02 140)",
      "--sidebar-accent": "oklch(0.8 0.18 40)",
      "--sidebar-accent-foreground": "oklch(0.08 0.02 140)",
      "--sidebar-border": "oklch(0.25 0.04 140)",
      "--sidebar-ring": "oklch(0.75 0.2 140)",
      "--shadow-sm": "0 0 2px oklch(0.75 0.2 140 / 0.3)",
      "--shadow": "0 0 4px oklch(0.75 0.2 140 / 0.4)",
      "--shadow-md": "0 0 8px oklch(0.75 0.2 140 / 0.5)",
      "--shadow-lg": "0 0 16px oklch(0.75 0.2 140 / 0.6)",
      "--shadow-xl": "0 0 24px oklch(0.75 0.2 140 / 0.7)"
    }
  },
  "css": {
    "@layer base": {
      "body": {
        "background": "var(--background)",
        "color": "var(--foreground)"
      },
      "*": {
        "border-color": "var(--border)"
      }
    }
  },
  "meta": {
    "category": "styles",
    "version": "1.0.0"
  },
  "type": "registry:theme"
}