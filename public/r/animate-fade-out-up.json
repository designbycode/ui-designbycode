{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-fade-out-up",
  "cssVars": {
    "theme": {
      "--animate-fade-out-up": "fadeOutUp 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes fadeOutUp": {
        "0%": {
          "opacity": "1"
        },
        "100%": {
          "opacity": "0",
          "transform": "translate3d(0, -100%, 0)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}