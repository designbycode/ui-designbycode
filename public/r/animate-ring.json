{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-ring",
  "cssVars": {
    "theme": {
      "--animate-ring": "ring 0.5s ease-in-out"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes ring": {
        "0%, 100%": {
          "transform": "rotate(0deg)"
        },
        "10%, 30%": {
          "transform": "rotate(15deg)"
        },
        "20%, 40%": {
          "transform": "rotate(-15deg)"
        },
        "50%, 70%": {
          "transform": "rotate(10deg)"
        },
        "60%, 80%": {
          "transform": "rotate(-10deg)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}