{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-expand",
  "cssVars": {
    "theme": {
      "--animate-expand": "expand 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes expand": {
        "0%": {
          "transform": "scale(0)",
          "opacity": "0"
        },
        "100%": {
          "transform": "scale(1)",
          "opacity": "1"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}