{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-slide-in-up",
  "title": "Animate Slide In Up",
  "author": "designbycode",
  "cssVars": {
    "theme": {
      "--animate-slide-in-up": "slideInUp 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes slideInUp": {
        "0%": {
          "transform": "translate3d(0, 100%, 0)",
          "visibility": "visible"
        },
        "100%": {
          "transform": "translate3d(0, 0, 0)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}