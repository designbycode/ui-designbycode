{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-swing",
  "cssVars": {
    "theme": {
      "--animate-swing": "swing 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes swing": {
        "20%": {
          "transform": "rotate3d(0, 0, 1, 15deg)"
        },
        "40%": {
          "transform": "rotate3d(0, 0, 1, -10deg)"
        },
        "60%": {
          "transform": "rotate3d(0, 0, 1, 5deg)"
        },
        "80%": {
          "transform": "rotate3d(0, 0, 1, -5deg)"
        },
        "100%": {
          "transform": "rotate3d(0, 0, 1, 0deg)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}