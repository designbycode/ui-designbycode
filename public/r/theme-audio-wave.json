{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme-audio-wave",
  "title": "Theme Audio Wave",
  "author": "designbycode",
  "registryDependencies": [
    "https://ui.designbycode.co.za/r/font-inter.json",
    "https://ui.designbycode.co.za/r/font-bebas-neue.json",
    "https://ui.designbycode.co.za/r/font-fira-mono.json"
  ],
  "cssVars": {
    "theme": {
      "font-sans": "Inter, sans-serif",
      "font-serif": "Bebas Neue, sans-serif",
      "font-mono": "Fira Code, monospace",
      "radius": "0.5rem"
    },
    "light": {},
    "dark": {
      "background": "oklch(0.08 0.02 285)",
      "foreground": "oklch(0.98 0.01 285)",
      "primary": "oklch(0.72 0.25 145)",
      "primary-foreground": "oklch(0.08 0.02 285)",
      "secondary": "oklch(0.25 0.02 285)",
      "secondary-foreground": "oklch(0.95 0.01 285)",
      "muted": "oklch(0.18 0.02 285)",
      "muted-foreground": "oklch(0.70 0.02 285)",
      "accent": "oklch(0.75 0.22 330)",
      "accent-foreground": "oklch(0.08 0.02 285)",
      "destructive": "oklch(0.65 0.22 25)",
      "destructive-foreground": "oklch(0.98 0.01 285)",
      "border": "oklch(0.25 0.02 285)",
      "input": "oklch(0.25 0.02 285)",
      "ring": "oklch(0.72 0.25 145)",
      "chart-1": "oklch(0.72 0.25 145)",
      "chart-2": "oklch(0.75 0.22 330)",
      "chart-3": "oklch(0.65 0.18 260)",
      "chart-4": "oklch(0.80 0.20 40)",
      "chart-5": "oklch(0.55 0.15 200)"
    }
  },
  "css": {
    "@layer base": {
      "body": {
        "background": "var(--background)",
        "color": "var(--foreground)"
      },
      "*": {
        "border-color": "var(--border)"
      }
    }
  },
  "meta": {
    "category": "styles",
    "version": "1.0.0"
  },
  "type": "registry:style"
}