{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-roll-in",
  "cssVars": {
    "theme": {
      "--animate-roll-in": "rollIn 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes rollIn": {
        "0%": {
          "opacity": "0",
          "transform": "translate3d(-100%, 0, 0) rotate3d(0, 0, 1, -120deg)"
        },
        "100%": {
          "opacity": "1",
          "transform": "translate3d(0, 0, 0) rotate3d(0, 0, 1, 0deg)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}