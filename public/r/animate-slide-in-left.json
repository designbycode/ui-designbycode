{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-slide-in-left",
  "cssVars": {
    "theme": {
      "--animate-slide-in-left": "slideInLeft 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes slideInLeft": {
        "0%": {
          "transform": "translate3d(-100%, 0, 0)",
          "visibility": "visible"
        },
        "100%": {
          "transform": "translate3d(0, 0, 0)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}