{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-bell",
  "cssVars": {
    "theme": {
      "--animate-bell": "bell 1s ease-in-out"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes bell": {
        "0%": {
          "transform": "rotate(0)"
        },
        "10%": {
          "transform": "rotate(15deg)"
        },
        "20%": {
          "transform": "rotate(-15deg)"
        },
        "30%": {
          "transform": "rotate(10deg)"
        },
        "40%": {
          "transform": "rotate(-10deg)"
        },
        "50%": {
          "transform": "rotate(0)"
        },
        "100%": {
          "transform": "rotate(0)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}