{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-heart-beat",
  "cssVars": {
    "theme": {
      "--animate-heart-beat": "heartBeat 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes heartBeat": {
        "0%": {
          "transform": "scale(1)"
        },
        "14%": {
          "transform": "scale(1.3)"
        },
        "28%": {
          "transform": "scale(1)"
        },
        "42%": {
          "transform": "scale(1.3)"
        },
        "70%": {
          "transform": "scale(1)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}