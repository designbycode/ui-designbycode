{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-blur-in",
  "cssVars": {
    "theme": {
      "--animate-blur-in": "blurIn 0.6s ease-out"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes blurIn": {
        "0%": {
          "filter": "blur(12px)",
          "opacity": "0"
        },
        "100%": {
          "filter": "blur(0px)",
          "opacity": "1"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}