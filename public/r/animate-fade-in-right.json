{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "animate-fade-in-right",
  "cssVars": {
    "theme": {
      "--animate-fade-in-right": "fadeInRight 1s"
    }
  },
  "css": {
    "@layer utilities": {
      "@keyframes fadeInRight": {
        "0%": {
          "opacity": "0",
          "transform": "translate3d(100%, 0, 0)"
        },
        "100%": {
          "opacity": "1",
          "transform": "translate3d(0, 0, 0)"
        }
      }
    }
  },
  "meta": {
    "category": "animations",
    "version": "1.0.0"
  },
  "type": "registry:style"
}