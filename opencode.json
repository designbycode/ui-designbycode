{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": ["php", "artisan", "boost:mcp"]
        },
        "paddle": {
            "type": "local",
            "enabled": true,
            "command": ["npx", "-y", "@paddle/paddle-mcp"],
            "environment": {
                "PADDLE_API_KEY": "${PADDLE_API_KEY}",
                "PADDLE_ENVIRONMENT": "sandbox",
                "PADDLE_TOOLS": "non-destructive"
            }
        }
    }
}
