{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": ["artisan", "boost:mcp"]
        },
        "paddle": {
            "command": "npx",
            "args": [
                "-y",
                "@paddle/paddle-mcp",
                "--api-key=${PADDLE_API_KEY}",
                "--environment=sandbox",
                "--tools=non-destructive"
            ]
        }
    }
}
